  ClientEvents.lang('en_us', event =>{
  let discLang = {
    'exsanguination:music_disc_voidlit_nether:': 'Berlium - Under The Voidlit Nether'
  }
  for (let [id, txt] of Object.entries(discLang)) {
    event.add('exsanguination', `item.kubejs.music_disc_${id}`, 'Music Disc')
    event.add('exsanguination', `item.kubejs.music_disc_${id}.desc`, txt)
  }
})
